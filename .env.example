# C2CAD-Bench API keys
# Copy this file to .env and fill in your keys.
# Only the providers you intend to benchmark need keys.

# Google (Gemini models)
GOOGLE_API_KEY=

# Anthropic (Claude models)
ANTHROPIC_API_KEY=

# OpenAI (GPT models)
OPENAI_API_KEY=

# DeepSeek (V3.2, R1)
DEEPSEEK_API_KEY=

# Kimi / Moonshot AI (K2.5)
MOONSHOT_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Groq
GROQ_API_KEY=
