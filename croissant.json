  "@type": "sc:Dataset",
  "name": "C2CAD-Bench",
  "description": "A benchmark dataset for evaluating language-agnostic 3D spatial reasoning in large language models. The dataset contains natural-language CAD-style prompts, deterministic golden JSON references, model JSON outputs, and per-case scores for 25 test families, 75 test cases, and 13 evaluated LLMs.",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "license": "https://spdx.org/licenses/MIT.html",
  "url": "https://github.com/c2cad-bench/c2cad-bench",
  "creator": [
    {
      "@type": "Organization",
      "name": "Anonymous Authors"
    }
  ],
  "datePublished": "2026-04-11",
  "version": "1.0",
  "keywords": [
    "3D spatial reasoning",
    "CAD",
    "large language models",
    "benchmark",
    "evaluation"
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "cases_jsonl",
      "name": "data/cases.jsonl",
      "description": "Benchmark prompts and golden references.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/data/cases.jsonl",
      "encodingFormat": "application/jsonl",
      "md5": "d324e21c61b36f14223ec3bae7cd9d4f"
    },
    {
      "@type": "cr:FileObject",
      "@id": "model_outputs_jsonl",
      "name": "data/model_outputs.jsonl",
      "description": "Model outputs and per-case scores.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/data/model_outputs.jsonl",
      "encodingFormat": "application/jsonl",
      "md5": "4f4df45fe89fdff6f5b88d506dcdcff8"
    },
    {
      "@type": "cr:FileObject",
      "@id": "scores_csv",
      "name": "data/scores.csv",
      "description": "Tabular per-case score table.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/data/scores.csv",
      "encodingFormat": "text/csv",
      "md5": "27b71645feb3482a3b32c49be70b50b2"
    },
    {
      "@type": "cr:FileObject",
      "@id": "model_summary_csv",
      "name": "data/model_summary.csv",
      "description": "Aggregate model-level score summary.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/data/model_summary.csv",
      "encodingFormat": "text/csv",
      "md5": "c3c5162c57e76ad1e18a3cdc696c3a6f"
    },
    {
      "@type": "cr:FileObject",
      "@id": "showcase_db_js",
      "name": "results/showcase_db.js",
      "description": "Original self-contained result database used by the viewer.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/results/showcase_db.js",
      "encodingFormat": "application/javascript",
      "md5": "c7a62159e97efe207614e6a26155e7ec"
    },
    {
      "@type": "cr:FileObject",
      "@id": "prompt_audit_csv",
      "name": "data/prompt_audit.csv",
      "description": "Prompt scaffolding audit generated by scripts/audit_prompts.py.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/data/prompt_audit.csv",
      "encodingFormat": "text/csv",
      "md5": "d063bfdac1d2523c4fccba3bf47349c0"
    },
    {
      "@type": "cr:FileObject",
      "@id": "run_manifest_neurips2026_json",
      "name": "results/run_manifest_neurips2026.json",
      "description": "Evaluation policy and artifact manifest for the paper snapshot.",
      "contentUrl": "https://raw.githubusercontent.com/c2cad-bench/c2cad-bench/main/results/run_manifest_neurips2026.json",
      "encodingFormat": "application/json",
      "md5": "20411dec1f462b719b108241f92a8c55"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "cases",
      "name": "cases",
      "description": "The 75 benchmark cases, including prompts and golden references.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "cases/case_id",
          "name": "case_id",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "cases_jsonl"
            },
            "extract": {
              "jsonPath": "$.case_id"
            }
          }
        },
        {
